# Ghost in the Data - Backend configuration
GOOGLE_API_KEY=your_gemini_api_key_here
# Optional override (google-genai). Examples: gemini-2.5-flash, gemini-2.5-pro
GEMINI_MODEL=gemini-2.5-flash
NEWSDATA_API_KEY=your_newsdata_api_key_here
PORT=8000
HOST=0.0.0.0

# Persistence (PostgreSQL)
# In Docker Compose, the backend uses the `db` service hostname.
DATABASE_URL=postgresql+asyncpg://ghost:ghost@db:5432/ghost
